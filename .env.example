# Copy this file to .env and adjust values for your local environment.
# .env is gitignored; do not commit real secrets.

# Postgres connection (consumed by compose.yaml and the Spring Boot app)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=alexandria
DB_USERNAME=alexandria
DB_PASSWORD=alexandria

# JWT signing secret (HS256). Generate a strong random value for non-local use.
JWT_SECRET=change-me-to-a-long-random-string
